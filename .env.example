# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Number of parallel companies to search at once (5 is a good default)
MAX_WORKERS=5

# Number of parallel Playwright (headless Chrome) instances for JS-heavy pages
PW_WORKERS=2

# Set to true to skip Playwright entirely — much faster for large CSVs,
# small chance of missing companies with JS-only career pages
SKIP_PLAYWRIGHT=false
