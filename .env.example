# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Custom Search API key — get yours at https://console.cloud.google.com
GOOGLE_API_KEY=

# Google Custom Search Engine ID — create one at https://programmablesearchengine.google.com
GOOGLE_CSE_ID=

# Number of companies to search in parallel (lower = gentler on APIs, default 3)
MAX_WORKERS=3
